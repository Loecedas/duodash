---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found">
  <div class="flex-1 flex items-center justify-center">
    <div class="text-center">
      <h1 class="text-6xl font-extrabold text-gray-800 mb-2">404</h1>
      <p class="text-xl text-gray-600 mb-10">Page Not Found</p>
      <a 
        href="/" 
        class="inline-block px-6 py-3 bg-[#58cc02] text-white font-bold rounded-xl border-2 border-b-4 border-[#46a302] hover:bg-[#46a302] transition-colors"
      >
        Go Home
      </a>
    </div>
  </div>
</Layout>
